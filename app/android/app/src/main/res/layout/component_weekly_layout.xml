<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <androidx.constraintlayout.widget.Guideline
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:id="@+id/guide_1"
        app:layout_constraintGuide_percent="0.143"
        />
    <androidx.constraintlayout.widget.Guideline
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:id="@+id/guide_2"
        app:layout_constraintGuide_percent="0.286"
        />
    <androidx.constraintlayout.widget.Guideline
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:id="@+id/guide_3"
        app:layout_constraintGuide_percent="0.429"
        />
    <androidx.constraintlayout.widget.Guideline
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:id="@+id/guide_4"
        app:layout_constraintGuide_percent="0.572"
        />
    <androidx.constraintlayout.widget.Guideline
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:id="@+id/guide_5"
        app:layout_constraintGuide_percent="0.715"
        />
    <androidx.constraintlayout.widget.Guideline
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:id="@+id/guide_6"
        app:layout_constraintGuide_percent="0.858"
        />
    <View
        android:layout_width="0.5dp"
        android:layout_height="match_parent"
        android:background="@color/dividerColor"
        app:layout_constraintLeft_toLeftOf="@id/guide_1"
        />
    <View
        android:layout_width="0.5dp"
        android:layout_height="match_parent"
        android:background="@color/dividerColor"
        app:layout_constraintLeft_toLeftOf="@id/guide_2"
        />
    <View
        android:layout_width="0.5dp"
        android:layout_height="match_parent"
        android:background="@color/dividerColor"
        app:layout_constraintLeft_toLeftOf="@id/guide_3"
        />
    <View
        android:layout_width="0.5dp"
        android:layout_height="match_parent"
        android:background="@color/dividerColor"
        app:layout_constraintLeft_toLeftOf="@id/guide_4"
        />
    <View
        android:layout_width="0.5dp"
        android:layout_height="match_parent"
        android:background="@color/dividerColor"
        app:layout_constraintLeft_toLeftOf="@id/guide_5"
        />
    <View
        android:layout_width="0.5dp"
        android:layout_height="match_parent"
        android:background="@color/dividerColor"
        app:layout_constraintLeft_toLeftOf="@id/guide_6"
        />
    <View
        android:layout_width="match_parent"
        android:layout_height="0.5dp"
        android:background="@color/dividerColor"
        app:layout_constraintBottom_toBottomOf="parent"
        />
    <com.jun.weather.ui.component.WeeklyItemView
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:id="@+id/weekly_item_1"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toLeftOf="@id/guide_1"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        />
    <com.jun.weather.ui.component.WeeklyItemView
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:id="@+id/weekly_item_2"
        app:layout_constraintLeft_toRightOf="@id/guide_1"
        app:layout_constraintRight_toLeftOf="@id/guide_2"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        />
    <com.jun.weather.ui.component.WeeklyItemView
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:id="@+id/weekly_item_3"
        app:layout_constraintLeft_toRightOf="@id/guide_2"
        app:layout_constraintRight_toLeftOf="@id/guide_3"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        />
    <com.jun.weather.ui.component.WeeklyItemView
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:id="@+id/weekly_item_4"
        app:layout_constraintLeft_toRightOf="@id/guide_3"
        app:layout_constraintRight_toLeftOf="@id/guide_4"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        />
    <com.jun.weather.ui.component.WeeklyItemView
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:id="@+id/weekly_item_5"
        app:layout_constraintLeft_toRightOf="@id/guide_4"
        app:layout_constraintRight_toLeftOf="@id/guide_5"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        />
    <com.jun.weather.ui.component.WeeklyItemView
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:id="@+id/weekly_item_6"
        app:layout_constraintLeft_toRightOf="@id/guide_5"
        app:layout_constraintRight_toLeftOf="@id/guide_6"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        />
    <com.jun.weather.ui.component.WeeklyItemView
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:id="@+id/weekly_item_7"
        app:layout_constraintLeft_toRightOf="@id/guide_6"
        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        />
</androidx.constraintlayout.widget.ConstraintLayout>